# Veritabani baglanti bilgileri
# docker-compose.yml'deki user/password/db ile birebir ayni olmali.
# Not: host portu 5433 (5432'yi baska proje kullaniyordu).
# Surucu olarak psycopg (v3) kullaniyoruz -> postgresql+psycopg
DATABASE_URL=postgresql+psycopg://thermalgrid:1234@localhost:5433/thermalgrid_db

# JWT token'lari imzalamak icin gizli anahtar. Gercek projede uzun ve rastgele olmali.
SECRET_KEY=thermalgrid-gizli-anahtar-proje2-2026
